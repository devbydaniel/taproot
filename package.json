{
  "name": "taproot",
  "private": true,
  "version": "0.10.0",
  "description": "Self-hosted fractal outliner with wiki-links and linked references",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p server && tsc --noEmit -p client",
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint .",
    "dup": "jscpd shared/src server/src client/src --min-lines 25 --min-tokens 60 --ignore '**/*.test.ts' --threshold 0",
    "knip": "knip",
    "check": "prettier --check . && npm run lint && npm run typecheck && npm run dup && npm run knip && npm test",
    "prepare": "husky"
  },
  "overrides": {
    "lodash-es": "^4.18.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,css,mjs,html,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "concurrently": "^9.1.0",
    "eslint": "10.6.0",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-sonarjs": "4.1.0",
    "husky": "9.1.7",
    "jscpd": "5.0.11",
    "knip": "6.24.0",
    "lint-staged": "17.0.8",
    "prettier": "^3.4.2",
    "syncpack": "15.3.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^3.0.5"
  }
}
